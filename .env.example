# Authentication
# Set a strong password — this gates access to the entire app
ACCESS_PASSWORD=your-secret-password

# Vercel Blob Storage
# Auto-created when you connect a Blob store to the project in Vercel dashboard
# Pull locally with: npx vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# Ratings API — shared secret for n8n workflow to push ratings
RATINGS_API_KEY=
